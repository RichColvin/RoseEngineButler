net x-ena-btn                            => x-ena-flip.clk
net x-ena-panel                          <= x-ena-flip.out
net x-ena-panel                          => x-ena-and.in0
net x-ena-panel                          => x-ena-not.in
net x-ena-panel-inv                      <= x-ena-not.out
net x-ena-panel-inv                      => x-ena-flip.data
# net x-ena-settings-allow                 <= REBHlp.X_Ena_Override
net x-ena-settings-allow                 => x-ena-and.in1
net x-enable                             <= x-ena-and.out
net x-enable                             => gladevcp.X_ENA_Status

# Z Axis ***********************************
loadrt and2 names=z-ena-and
loadrt flipflop names=z-ena-flip
loadrt not names=z-ena-not
addf z-ena-not servo-thread
addf z-ena-flip servo-thread
addf z-ena-and servo-thread

net z-ena-btn                            <= gladevcp.Z_ENA
net z-ena-btn                            => z-ena-flip.clk
net z-ena-panel                          <= z-ena-flip.out
net z-ena-panel                          => z-ena-and.in0
net z-ena-panel                          => z-ena-not.in
net z-ena-panel-inv                      <= z-ena-not.out
net z-ena-panel-inv                      => z-ena-flip.data
# net z-ena-settings-allow                 <= REBHlp.Z_Ena_Override
net z-ena-settings-allow                 => z-ena-and.in1
net z-enable                             <= z-ena-and.out
net z-enable                             => gladevcp.Z_ENA_Status

# U Axis ***********************************
loadrt and2 names=u-ena-and
loadrt flipflop names=u-ena-flip
loadrt not names=u-ena-not
addf u-ena-not servo-thread
addf u-ena-flip servo-thread
addf u-ena-and servo-thread

net u-ena-btn                            <= gladevcp.U_ENA
net u-ena-btn                            => u-ena-flip.clk
net u-ena-panel                          <= u-ena-flip.out
net u-ena-panel                          => u-ena-and.in0
net u-ena-panel                          => u-ena-not.in
net u-ena-panel-inv                      <= u-ena-not.out
net u-ena-panel-inv                      => u-ena-flip.data
# net u-ena-settings-allow                 <= REBHlp.U_Ena_Override
net u-ena-settings-allow                 => u-ena-and.in1
net u-enable                             <= u-ena-and.out
net u-enable                             => gladevcp.U_ENA_Status

# V Axis ***********************************
loadrt and2 names=v-ena-and
loadrt flipflop names=v-ena-flip
loadrt not names=v-ena-not
addf v-ena-not servo-thread
addf v-ena-flip servo-thread
addf v-ena-and servo-thread

net v-ena-btn                            <= gladevcp.V_ENA
net v-ena-btn                            => v-ena-flip.clk
net v-ena-panel                          <= v-ena-flip.out
net v-ena-panel                          => v-ena-and.in0
net v-ena-panel                          => v-ena-not.in
net v-ena-panel-inv                      <= v-ena-not.out
net v-ena-panel-inv                      => v-ena-flip.data
# net v-ena-settings-allow                 <= REBHlp.V_Ena_Override
net v-ena-settings-allow                 => v-ena-and.in1
net v-enable                             <= v-ena-and.out
net v-enable                             => gladevcp.V_ENA_Status

# W Axis ***********************************
loadrt and2 names=w-ena-and
loadrt flipflop names=w-ena-flip
loadrt not names=w-ena-not
addf w-ena-not servo-thread
addf w-ena-flip servo-thread
addf w-ena-and servo-thread

net w-ena-btn                            <= gladevcp.W_ENA
net w-ena-btn                            => w-ena-flip.clk
net w-ena-panel                          <= w-ena-flip.out
net w-ena-panel                          => w-ena-and.in0
net w-ena-panel                          => w-ena-not.in
net w-ena-panel-inv                      <= w-ena-not.out
net w-ena-panel-inv                      => w-ena-flip.data
# net w-ena-settings-allow                 <= REBHlp.W_Ena_Override
net w-ena-settings-allow                 => w-ena-and.in1
net w-enable                             <= w-ena-and.out
net w-enable                             => gladevcp.W_ENA_Status
