#
# ********************************************************************
#
# Details about the fields are available in 
#   the LinuxCNC 2.9.4 System Manual
#   §12 Virtual Control Panels, starting on 
#   pg. 952
#
# ********************************************************************

# ********************************************************************
# Configuration values
#
#                                 Home   PCB
#  Axis  Joint  Channel   Type     Seq  Plug  Comments
#  ----  -----  -------  -------  ----  ----  ------------------------
#   X      0       02    LINEAR     1    P13
#   Y      -       --    ------     -		  Not available as LATHE=1
#   Z      1       00    LINEAR     2    P11
#
#   A      -       --    ------     -		  Not used
#   B      2       06    ANGULAR    3    P17
#   C      -       --    ------     -		  Not used
#
#   U      3       04    LINEAR     4    P15
#   V      4       01    LINEAR     5    P12
#   W      5       03    LINEAR     6    P14
#
#  Sp0     7       05      n/a     n/a   P16
#  Sp1     6       07      n/a     n/a   P18  Previously the C axis
# ********************************************************************

# ********************************************************************
# Setup the variables needed for the PyVCP Virtual Control Panels

# ******************************************
# Spindles

# Spindle 0 ********************************
loadrt and2 names=spindle.0-ena-and
loadrt flipflop names=spindle.0-ena-flip
loadrt not names=spindle.0-ena-not
addf spindle.0-ena-not servo-thread
addf spindle.0-ena-flip servo-thread
addf spindle.0-ena-and servo-thread

net spindle.0-ena-btn                   <=  gladevcp.Sp0_ENA
net spindle.0-ena-btn                    => spindle.0-ena-flip.clk
net spindle.0-ena-panel                 <=  spindle.0-ena-flip.out
net spindle.0-ena-panel                  => spindle.0-ena-and.in0
net spindle.0-ena-panel                  => spindle.0-ena-not.in
net spindle.0-ena-panel-inv             <=  spindle.0-ena-not.out
net spindle.0-ena-panel-inv              => spindle.0-ena-flip.data
# net spindle.0-ena-settings-allow        <=  REBHlp.Sp0_Ena_Override
net spindle.0-ena-settings-allow         => spindle.0-ena-and.in1
net spindle.0-enable                    <=  spindle.0-ena-and.out
net spindle.0-enable                     => gladevcp.Sp0_ENA_Status

# Spindle 1 ********************************
loadrt and2 names=spindle.1-ena-and
loadrt flipflop names=spindle.1-ena-flip
loadrt not names=spindle.1-ena-not
addf spindle.1-ena-not servo-thread
addf spindle.1-ena-flip servo-thread
addf spindle.1-ena-and servo-thread

net spindle.1-ena-btn                   <=  gladevcp.Sp1_ENA
net spindle.1-ena-btn                    => spindle.1-ena-flip.clk
net spindle.1-ena-panel                 <=  spindle.1-ena-flip.out
net spindle.1-ena-panel                  => spindle.1-ena-and.in0
net spindle.1-ena-panel                  => spindle.1-ena-not.in
net spindle.1-ena-panel-inv             <=  spindle.1-ena-not.out
net spindle.1-ena-panel-inv              => spindle.1-ena-flip.data
# net spindle.1-ena-settings-allow        <=  REBHlp.Sp1_Ena_Override
net spindle.1-ena-settings-allow         => spindle.1-ena-and.in1
net spindle.1-enable                    <=  spindle.1-ena-and.out
net spindle.1-enable                     => gladevcp.Sp1_ENA_Status

# ******************************************
# Rotary Axes

# B Axis ***********************************
loadrt and2 names=b-ena-and
loadrt flipflop names=b-ena-flip
loadrt not names=b-ena-not
addf b-ena-not servo-thread
addf b-ena-flip servo-thread
addf b-ena-and servo-thread

net b-ena-btn                            <= gladevcp.B_ENA
net b-ena-btn                            => b-ena-flip.clk
net b-ena-panel                          <= b-ena-flip.out
net b-ena-panel                          => b-ena-and.in0
net b-ena-panel                          => b-ena-not.in
net b-ena-panel-inv                      <= b-ena-not.out
net b-ena-panel-inv                      => b-ena-flip.data
# net b-ena-settings-allow                 <= REBHlp.B_Ena_Override
net b-ena-settings-allow                 => b-ena-and.in1
net b-enable                             <= b-ena-and.out
net b-enable                             => gladevcp.B_ENA_Status

# ******************************************
# Linear Axes

# X Axis ***********************************
loadrt and2 names=x-ena-and
loadrt flipflop names=x-ena-flip
loadrt not names=x-ena-not
addf x-ena-not servo-thread
addf x-ena-flip servo-thread
addf x-ena-and servo-thread

