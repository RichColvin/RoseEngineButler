#######################################################################
#
# ********************************************************************
#
# Details about the fields are available in 
#   the LinuxCNC 2.9.4 System Manual
#   §12 Virtual Control Panels, starting on 
#   pg. 952
#
# ********************************************************************

# ********************************************************************
# Configuration values
#
#                                 Home   PCB
#  Axis  Joint  Channel   Type     Seq  Plug  Comments
#  ----  -----  -------  -------  ----  ----  ------------------------
#   X      0       02    LINEAR     1    P13
#   Y      -       --    ------     -		  Not available as LATHE=1
#   Z      1       00    LINEAR     2    P11
#
#   A      -       --    ------     -		  Not used
#   B      2       06    ANGULAR    3    P17
#   C      -       --    ------     -		  Not used
#
#   U      3       04    LINEAR     4    P15
#   V      4       01    LINEAR     5    P12
#   W      5       03    LINEAR     6    P14
#
#  Sp0     7       05      n/a     n/a   P16
#  Sp1     6       07      n/a     n/a   P18  Previously the C axis
# ********************************************************************

# ********************************************************************
# Setup the variables needed for the PyVCP Virtual Control Panels

# ENA buttons (Sp0, Sp1, B, X, Z, U, V, W) are momentary HAL_Buttons;
# each click toggles that axis's enable via a flipflop (a D-type
# flip-flop - pins: data, clk, set, reset, out - made into a toggle
# by feeding its own inverted output back into "data", so each clk
# rising edge flips "out" without the button staying visually
# pressed in). X additionally ANDs in an independent "allow" pin
# owned by the Settings tab (REBHlp.X_Ena_Override), so the Settings
# tab can force X disabled regardless of the panel button's state.
#
# All instances of a given realtime component must be declared in a
# single loadrt line - the underlying kernel module can only be
# inserted once.
loadrt flipflop names=sp0-ena-flip,sp1-ena-flip,b-ena-flip,x-ena-flip,z-ena-flip,u-ena-flip,v-ena-flip,w-ena-flip
loadrt not names=sp0-ena-not,sp1-ena-not,b-ena-not,x-ena-not,z-ena-not,u-ena-not,v-ena-not,w-ena-not
loadrt and2 names=x-ena-and

# ******************************************
# Spindles

addf sp0-ena-not servo-thread
addf sp1-ena-not servo-thread
addf sp0-ena-flip servo-thread
addf sp1-ena-flip servo-thread

# net spindle.0-vel-cmd-rpm 				 => gladevcp.Sp0_Spd
net sp0-ena-btn                          <= gladevcp.Sp0_ENA
net sp0-ena-btn                          => sp0-ena-flip.clk
net spindle.0-enable                     <= sp0-ena-flip.out
net spindle.0-enable                     => gladevcp.Sp0_ENA_Status
net spindle.0-enable                     => sp0-ena-not.in
net sp0-ena-inv                          <= sp0-ena-not.out
net sp0-ena-inv                          => sp0-ena-flip.data

# net spindle.1-vel-cmd-rpm 				 => gladevcp.Sp1_Spd
net sp1-ena-btn                          <= gladevcp.Sp1_ENA
net sp1-ena-btn                          => sp1-ena-flip.clk
net spindle.1-enable                     <= sp1-ena-flip.out
net spindle.1-enable                     => gladevcp.Sp1_ENA_Status
net spindle.1-enable                     => sp1-ena-not.in
net sp1-ena-inv                          <= sp1-ena-not.out
net sp1-ena-inv                          => sp1-ena-flip.data

# ******************************************
# Rotary Axes

addf b-ena-not servo-thread
addf b-ena-flip servo-thread

# net b-vel-cmd							 => gladevcp.B_Spd
# net b-pos-fb							 => gladevcp.B_DRO
net b-ena-btn                            <= gladevcp.B_ENA
net b-ena-btn                            => b-ena-flip.clk
net b-enable                             <= b-ena-flip.out
net b-enable                             => gladevcp.B_ENA_Status
net b-enable                             => b-ena-not.in
net b-ena-inv                            <= b-ena-not.out
net b-ena-inv                            => b-ena-flip.data

# ******************************************
# Linear Axes

# net x-vel-cmd							 => gladevcp.X_Spd
# net x-pos-fb							 => gladevcp.X_DRO

addf x-ena-not servo-thread
addf x-ena-flip servo-thread
addf x-ena-and servo-thread

net x-ena-btn                            <= gladevcp.X_ENA
net x-ena-btn                            => x-ena-flip.clk
net x-ena-panel                          <= x-ena-flip.out
net x-ena-panel                          => x-ena-and.in0
net x-ena-panel                          => x-ena-not.in
net x-ena-panel-inv                      <= x-ena-not.out
net x-ena-panel-inv                      => x-ena-flip.data
net x-ena-settings-allow                 <= REBHlp.X_Ena_Override
net x-ena-settings-allow                 => x-ena-and.in1
net x-enable                             <= x-ena-and.out
net x-enable                             => gladevcp.X_ENA_Status

# net y-vel-cmd							 => gladevcp.Y_Spd
# net y-pos-fb							 => gladevcp.Y_DRO
# net y-enable        		             => gladevcp.Y_ENA_Status
# net y-enable							<=  gladevcp.Y_ENA

addf z-ena-not servo-thread
addf u-ena-not servo-thread
addf v-ena-not servo-thread
addf w-ena-not servo-thread
addf z-ena-flip servo-thread
addf u-ena-flip servo-thread
addf v-ena-flip servo-thread
addf w-ena-flip servo-thread

# net z-vel-cmd							 => gladevcp.Z_Spd
# net z-pos-fb							 => gladevcp.Z_DRO
net z-ena-btn                            <= gladevcp.Z_ENA
net z-ena-btn                            => z-ena-flip.clk
net z-enable                             <= z-ena-flip.out
net z-enable                             => gladevcp.Z_ENA_Status
net z-enable                             => z-ena-not.in
net z-ena-inv                            <= z-ena-not.out
net z-ena-inv                            => z-ena-flip.data

# net u-vel-cmd							 => gladevcp.U_Spd
# net u-pos-fb							 => gladevcp.U_DRO
net u-ena-btn                            <= gladevcp.U_ENA
net u-ena-btn                            => u-ena-flip.clk
net u-enable                             <= u-ena-flip.out
net u-enable                             => gladevcp.U_ENA_Status
net u-enable                             => u-ena-not.in
net u-ena-inv                            <= u-ena-not.out
net u-ena-inv                            => u-ena-flip.data

# net v-vel-cmd							 => gladevcp.V_Spd
# net v-pos-fb							 => gladevcp.V_DRO
net v-ena-btn                            <= gladevcp.V_ENA
net v-ena-btn                            => v-ena-flip.clk
net v-enable                             <= v-ena-flip.out
net v-enable                             => gladevcp.V_ENA_Status
net v-enable                             => v-ena-not.in
net v-ena-inv                            <= v-ena-not.out
net v-ena-inv                            => v-ena-flip.data

# net w-vel-cmd							 => gladevcp.W_Spd
# net w-pos-fb							 => gladevcp.W_DRO
net w-ena-btn                            <= gladevcp.W_ENA
net w-ena-btn                            => w-ena-flip.clk
net w-enable                             <= w-ena-flip.out
net w-enable                             => gladevcp.W_ENA_Status
net w-enable                             => w-ena-not.in
net w-ena-inv                            <= w-ena-not.out
net w-ena-inv                            => w-ena-flip.data
